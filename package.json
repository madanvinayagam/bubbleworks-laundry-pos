{
  "name": "bubbleworks-laundry-management",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @bubbleworks/legacy-pos",
    "dev:legacy": "npm run dev -w @bubbleworks/legacy-pos",
    "dev:api": "npm run dev -w @bubbleworks/api",
    "dev:web": "npm run dev -w @bubbleworks/web",
    "build": "npm run build -w @bubbleworks/legacy-pos",
    "build:legacy": "npm run build -w @bubbleworks/legacy-pos",
    "build:api": "npm run build -w @bubbleworks/api",
    "build:web": "npm run build -w @bubbleworks/web",
    "build:shared": "npm run build -w @bubbleworks/shared",
    "build:vercel": "npm run build:shared && npm run build:web",
    "build:dev": "npm run build -w @bubbleworks/legacy-pos -- --mode development",
    "lint": "eslint .",
    "preview": "npm run preview -w @bubbleworks/legacy-pos",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.14.0",
    "bcryptjs": "^3.0.2",
    "dotenv": "^17.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "^22.16.5",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.32.0",
    "globals": "^15.15.0",
    "postcss": "^8.5.6",
    "prisma": "^6.14.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Dhinesh71/Auto-Receipt-printer/issues"
  },
  "homepage": "https://github.com/Dhinesh71/Auto-Receipt-printer#readme"
}
